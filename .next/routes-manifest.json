{
  "version": 3,
  "pages404": true,
  "caseSensitive": false,
  "basePath": "",
  "redirects": [
    {
      "source": "/:path+/",
      "destination": "/:path+",
      "internal": true,
      "priority": true,
      "statusCode": 308,
      "regex": "^(?:/((?:[^/]+?)(?:/(?:[^/]+?))*))/$"
    },
    {
      "source": "/services/bathroom-rough-in",
      "destination": "/services/bathroom-plumbing",
      "statusCode": 308,
      "regex": "^(?!/_next)/services/bathroom-rough-in(?:/)?$"
    },
    {
      "source": "/services/bathroom-finishing",
      "destination": "/services/bathroom-plumbing",
      "statusCode": 308,
      "regex": "^(?!/_next)/services/bathroom-finishing(?:/)?$"
    },
    {
      "source": "/services/laundry-connections",
      "destination": "/services/installations",
      "statusCode": 308,
      "regex": "^(?!/_next)/services/laundry-connections(?:/)?$"
    },
    {
      "source": "/services/repairs-troubleshooting",
      "destination": "/services/leak-repairs",
      "statusCode": 308,
      "regex": "^(?!/_next)/services/repairs-troubleshooting(?:/)?$"
    },
    {
      "source": "/services/kitchen-plumbing",
      "destination": "/services/kitchen-plumbing-v2",
      "statusCode": 308,
      "regex": "^(?!/_next)/services/kitchen-plumbing(?:/)?$"
    }
  ],
  "headers": [],
  "rewrites": {
    "beforeFiles": [],
    "afterFiles": [],
    "fallback": []
  },
  "dynamicRoutes": [
    {
      "page": "/services/[slug]",
      "regex": "^/services/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPslug": "nxtPslug"
      },
      "namedRegex": "^/services/(?<nxtPslug>[^/]+?)(?:/)?$"
    }
  ],
  "staticRoutes": [
    {
      "page": "/",
      "regex": "^/(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/(?:/)?$"
    },
    {
      "page": "/_global-error",
      "regex": "^/_global\\-error(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/_global\\-error(?:/)?$"
    },
    {
      "page": "/_not-found",
      "regex": "^/_not\\-found(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/_not\\-found(?:/)?$"
    },
    {
      "page": "/about",
      "regex": "^/about(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/about(?:/)?$"
    },
    {
      "page": "/api/admin/services/categories",
      "regex": "^/api/admin/services/categories(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/api/admin/services/categories(?:/)?$"
    },
    {
      "page": "/api/admin/services/items",
      "regex": "^/api/admin/services/items(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/api/admin/services/items(?:/)?$"
    },
    {
      "page": "/api/google-reviews",
      "regex": "^/api/google\\-reviews(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/api/google\\-reviews(?:/)?$"
    },
    {
      "page": "/api/quotes",
      "regex": "^/api/quotes(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/api/quotes(?:/)?$"
    },
    {
      "page": "/api/services",
      "regex": "^/api/services(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/api/services(?:/)?$"
    },
    {
      "page": "/privacy",
      "regex": "^/privacy(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/privacy(?:/)?$"
    },
    {
      "page": "/services",
      "regex": "^/services(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/services(?:/)?$"
    },
    {
      "page": "/sitemap.xml",
      "regex": "^/sitemap\\.xml(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/sitemap\\.xml(?:/)?$"
    },
    {
      "page": "/terms",
      "regex": "^/terms(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/terms(?:/)?$"
    }
  ],
  "dataRoutes": [],
  "rsc": {
    "header": "rsc",
    "varyHeader": "rsc, next-router-state-tree, next-router-prefetch, next-router-segment-prefetch",
    "prefetchHeader": "next-router-prefetch",
    "didPostponeHeader": "x-nextjs-postponed",
    "contentTypeHeader": "text/x-component",
    "suffix": ".rsc",
    "prefetchSuffix": ".prefetch.rsc",
    "prefetchSegmentHeader": "next-router-segment-prefetch",
    "prefetchSegmentSuffix": ".segment.rsc",
    "prefetchSegmentDirSuffix": ".segments",
    "clientParamParsing": false,
    "dynamicRSCPrerender": false
  },
  "rewriteHeaders": {
    "pathHeader": "x-nextjs-rewritten-path",
    "queryHeader": "x-nextjs-rewritten-query"
  }
}