f:["$","h2",null,{"children":"5. Payment"}]
10:["$","p",null,{"children":"Payment terms will be communicated at the time of service. We accept various forms of payment as discussed with our team."}]
11:["$","h2",null,{"children":"6. Warranty"}]
12:["$","p",null,{"children":"We stand behind the quality of our work. Specific warranty terms will be provided with each service and may vary depending on the type of work performed."}]
