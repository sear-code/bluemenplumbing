# Supabase Configuration
# Get these from: https://app.supabase.com/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url_here
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Google Places API Configuration
# Get your API key from: https://console.cloud.google.com/google/maps-apis/credentials
# Make sure to enable the "Places API" in your Google Cloud Console
NEXT_PUBLIC_GOOGLE_PLACES_API_KEY=your_google_places_api_key_here

# Get your Place ID from: https://developers.google.com/maps/documentation/places/web-service/place-id
# Or use the Place ID Finder: https://developers.google.com/maps/documentation/javascript/examples/places-placeid-finder
NEXT_PUBLIC_GOOGLE_PLACE_ID=your_google_place_id_here

# Resend Email Configuration
# Get your API key from: https://resend.com/api-keys (sign up at https://resend.com)
# Note: In development, you can use Resend's test domain (onboarding@resend.dev)
# For production, you'll need to verify your own domain
RESEND_API_KEY=re_your_api_key_here
RESEND_FROM_EMAIL=quotes@yourdomain.com
RESEND_TO_EMAIL=your-business-email@example.com
